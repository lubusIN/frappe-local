{
  "name": "frappe-cafe",
  "productName": "Frappe Cafe",
  "version": "0.1.0",
  "type": "module",
  "description": "Desktop app for managing local Frappe benches and sites.",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "electron-forge package",
    "icons:generate": "node scripts/generate-icons.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "precommit:check": "bash scripts/precommit-check.sh",
    "dev:reset-state": "node scripts/reset-dev-state.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.renderer.json",
    "postinstall": "node scripts/download-binaries.js"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@eslint/js": "^9.25.1",
    "@iconify-json/lucide": "^1.2.103",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.5.0",
    "electron": "^35.1.5",
    "eslint": "^9.25.1",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "frappe-ui": "^0.1.51",
    "isomorphic-git": "^1.37.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "zod": "^3.24.2"
  }
}
