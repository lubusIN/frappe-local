{
  "name": "frappe-local",
  "productName": "Frappe Local",
  "version": "1.0.0-alpha.1",
  "type": "module",
  "description": "Desktop app for managing local Frappe benches and sites.",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "release:make": "node scripts/make-release.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && node scripts/typecheck-renderer.js",
    "test": "vitest run",
    "precommit:check": "bash scripts/precommit-check.sh",
    "icons:generate": "node scripts/generate-icons.js",
    "dev:reset-state": "node scripts/reset-dev-state.js",
    "postinstall": "node scripts/download-binaries.js"
  },
  "author": "Lubus",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/core": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@eslint/js": "^9.25.1",
    "@iconify-json/lucide": "^1.2.103",
    "@iconify/json": "^2.2.478",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.5.0",
    "electron": "^35.1.5",
    "eslint": "^9.25.1",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "lucide-static": "^1.16.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "unplugin-icons": "^23.0.1",
    "vite": "^5.4.21",
    "vitest": "^3.1.2",
    "vue-router": "^4.6.4"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "frappe-ui": "^1.0.0-beta.11",
    "vue": "^3.5.13",
    "zod": "^3.24.2"
  }
}
