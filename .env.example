# Frappe Cafe Build Environment Configuration
# Copy this to .env and fill in your values for production releases

# macOS Code Signing and Notarization
# Required for production macOS releases

# Your Apple ID email address
# APPLE_ID=your-apple-id@example.com

# App-specific password generated from Apple ID account settings
# https://appleid.apple.com/account/manage
# APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your Apple Developer Team ID
# https://developer.apple.com/account/resources/identifiers/list
# APPLE_TEAM_ID=XXXXXXXXXX

# macOS Code Signing Identity (optional, will be auto-detected if not set)
# APPLE_SIGN_IDENTITY=Developer ID Application: YOUR_NAME (TEAMID)

# Windows Code Signing (future, not yet implemented)
# WINDOWS_SIGN_CERT_PATH=./certs/code-sign-cert.pfx
# WINDOWS_SIGN_CERT_PASSWORD=your-cert-password

# Release Channel (stable or beta)
# RELEASE_CHANNEL=stable

# Telemetry (if implementing usage analytics)
# TELEMETRY_ENABLED=false
